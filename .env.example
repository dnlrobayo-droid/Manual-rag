# ============================================
# Manual RAG - Variables de entorno
# ============================================
# Copia este archivo como .env y rellena los valores
# cp .env.example .env

# API key de Anthropic (obtén la tuya en https://console.anthropic.com/)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Modelo de Claude a utilizar
ANTHROPIC_MODEL=claude-3-haiku-20240307

# Modelo de embeddings (SentenceTransformer, ejecuta localmente)
EMBEDDING_MODEL=all-MiniLM-L6-v2

# Directorio persistente de ChromaDB
CHROMA_PERSIST_DIR=./chroma_db

# Nombre de la colección en ChromaDB
CHROMA_COLLECTION=manuales_tecnicos

# Ruta a los PDFs de manuales
MANUALS_DIR=./data/manuals

# Parámetros de chunking
CHUNK_SIZE=500
CHUNK_OVERLAP=50

# Número de chunks a recuperar por consulta
TOP_K=4
